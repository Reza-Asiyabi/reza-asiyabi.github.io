---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Reza M. Asiyabi — AI Researcher',
  description = 'Personal portfolio of Reza M. Asiyabi, AI/ML researcher specializing in physics-aware deep learning and Earth Observation at the University of Edinburgh.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://reza-asiyabi.github.io/images/Profile.webp" />
    <meta property="og:url" content="https://reza-asiyabi.github.io" />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@reza_m_asiyabi" />

    <!-- No favicon -->

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent flash of wrong theme: apply saved preference before paint -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.add('light');
          }
        } catch (_) {}
      })();
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DGQ7BQQ1DV"
    ></script>
    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      // @ts-ignore
      function gtag() { dataLayer.push(arguments); }
      // @ts-ignore
      gtag('js', new Date());
      // @ts-ignore
      gtag('config', 'G-DGQ7BQQ1DV');
    </script>
  </head>

  <body class="bg-background text-foreground font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  /* ─── CSS custom property palette ────────────────────────────────────── */
  /* Values are raw RGB channels so Tailwind opacity modifiers work:        */
  /*   bg-surface/40  →  rgb(var(--c-surface) / 0.4)                       */

  :root {
    /* Dark theme (default) */
    --c-bg:            11 11 18;      /* #0b0b12 */
    --c-surface:       18 18 28;      /* #12121c */
    --c-stroke:        30 30 46;      /* #1e1e2e */
    --c-accent:        99 102 241;    /* #6366f1 indigo-500 */
    --c-accent-light:  129 140 248;   /* #818cf8 indigo-400 */
    --c-accent-violet: 167 139 250;   /* #a78bfa violet-400 */
    --c-fg:            226 232 240;   /* #e2e8f0 slate-200 */
    --c-muted:         148 163 184;   /* #94a3b8 slate-400 */
    --c-faint:         71  85  105;   /* #475569 slate-600 */
  }

  .light {
    --c-bg:            255 255 255;   /* #ffffff */
    --c-surface:       248 250 252;   /* #f8fafc slate-50 */
    --c-stroke:        226 232 240;   /* #e2e8f0 slate-200 */
    --c-accent:        79  70  229;   /* #4f46e5 indigo-600 */
    --c-accent-light:  99  102 241;   /* #6366f1 indigo-500 */
    --c-accent-violet: 124 58  237;   /* #7c3aed violet-600 */
    --c-fg:            15  23  42;    /* #0f172a slate-950 */
    --c-muted:         71  85  105;   /* #475569 slate-600 */
    --c-faint:         148 163 184;   /* #94a3b8 slate-400 */
  }

  /* ─── Scroll-triggered fade-in ─────────────────────────────────────── */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Custom scrollbar ─────────────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: rgb(var(--c-bg)); }
  ::-webkit-scrollbar-thumb { background: rgb(var(--c-stroke)); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: rgb(var(--c-accent)); }

  html { font-family: 'Inter', system-ui, sans-serif; }

  /* Smooth theme transitions (skip on initial page load to avoid FOUC) */
  .theme-ready * {
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease !important;
  }
</style>

<script>
  // Enable smooth theme transitions only after first paint
  requestAnimationFrame(() => {
    document.documentElement.classList.add('theme-ready');
  });

  // Intersection observer for fade-up animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>
