---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const travelPhotos = [
  { src: '/images/Travel/Amsterdam.webp', caption: 'Amsterdam, Netherlands' },
  { src: '/images/Travel/Paris - With Saqib.webp', caption: 'Paris, France' },
  { src: '/images/Travel/Paris.webp', caption: 'Paris, France' },
  { src: '/images/Travel/Venice - With Shaahin.webp', caption: 'Venice, Italy' },
  { src: '/images/Travel/Venice - Biennale.webp', caption: 'Biennale, Venice' },
  { src: '/images/Travel/Venice.webp', caption: 'Venice, Italy' },
  { src: '/images/Travel/Rome.webp', caption: 'Rome, Italy' },
  { src: '/images/Travel/Milan.webp', caption: 'Milan, Italy' },
  { src: '/images/Travel/Genoa.webp', caption: 'Genoa, Italy' },
  { src: '/images/Travel/Interlaken.webp', caption: 'Paragliding, Swiss Alps — Interlaken' },
  { src: '/images/Travel/Zurich.webp', caption: 'Zurich, Switzerland' },
  { src: '/images/Travel/Vienna.webp', caption: 'Vienna, Austria' },
  { src: '/images/Travel/Munich - Octoberfest.webp', caption: 'Oktoberfest, Munich, Germany' },
  { src: '/images/Travel/Frankfurt.webp', caption: 'Frankfurt, Germany' },
  { src: '/images/Travel/Berlin - With Omid and Shadi.webp', caption: 'Berlin, Germany' },
  { src: '/images/Travel/Madrid.webp', caption: 'Madrid, Spain' },
  { src: '/images/Travel/Santiago.webp', caption: 'Santiago de Compostela, Spain' },
  { src: '/images/Travel/Reykjavik - With Omid.webp', caption: 'Reykjavik, Iceland' },
  { src: '/images/Travel/Reykjavik - With Madison and Simon.webp', caption: 'Reykjavik, Iceland' },
  { src: '/images/Travel/Reykjavik - Student Bar.webp', caption: 'Reykjavik, Iceland' },
  { src: '/images/Travel/Reykjavik.webp', caption: 'Reykjavik, Iceland' },
  { src: '/images/Travel/Den Haag.webp', caption: 'The Hague, Netherlands' },
];

const sportsPhotos = [
  { src: '/images/Sports/Basketball.webp', caption: 'Basketball' },
  { src: '/images/Sports/Hiking.webp', caption: 'Hiking' },
  { src: '/images/Sports/Gym1.webp', caption: 'Gym' },
  { src: '/images/Sports/Gym2.webp', caption: 'Gym' },
  { src: '/images/Sports/Foosball.webp', caption: 'Foosball' },
];

const conferencePhotos = [
  { src: '/images/Conferences/Bonn - LPS.webp', caption: 'ESA Living Planet Symposium 2022, Bonn, Germany' },
  { src: '/images/Conferences/Bonn - LPS - With Omid and Amjad.webp', caption: 'ESA LPS 2022, Bonn — with colleagues' },
  { src: '/images/Conferences/Kuala Lumpor - IGARSS 2022 Presentation.webp', caption: 'IGARSS 2022 presentation, Kuala Lumpur, Malaysia' },
  { src: '/images/Conferences/Kuala Lumpor - IGARSS 2022.webp', caption: 'IGARSS 2022, Kuala Lumpur, Malaysia' },
  { src: '/images/Conferences/Kuala Lumpor - With the guys.webp', caption: 'IGARSS 2022, Kuala Lumpur — with colleagues' },
  { src: '/images/Conferences/Reykjavik - HDCR.webp', caption: 'IEEE GRSS HDCRS Summer School, Reykjavik, Iceland' },
  { src: '/images/Conferences/Santiago - MENELAOS Presentation.webp', caption: 'MENELAOS Mid-term Summer School, Santiago, Spain' },
  { src: '/images/Conferences/Siegen - MENELAOS Forum Presentation.webp', caption: 'MENELAOS Forum 2022, Siegen, Germany' },
  { src: '/images/Conferences/Siegen - MENELAOS Forum - Group.webp', caption: 'MENELAOS Forum 2022 — group photo, Siegen, Germany' },
  { src: '/images/Conferences/Siegen - MENELAOS Forum - With Saqib and Omid.webp', caption: 'MENELAOS Forum 2022 — with Saqib and Omid, Siegen' },
  { src: '/images/Conferences/Bucharest - MENELAOS Forum Presentation.webp', caption: 'MENELAOS Forum, Bucharest, Romania' },
  { src: '/images/Conferences/Bucharest - MENELAOS Forum - Dinner.webp', caption: 'MENELAOS Forum dinner, Bucharest, Romania' },
];

const sections = [
  {
    title: 'Travel',
    subtitle: "The world is pretty amazing — here are some of the places I've had the pleasure of exploring.",
    photos: travelPhotos,
    icon: '✈️',
  },
  {
    title: 'Sports',
    subtitle: 'Exercise and sport are part of my daily routine — basketball, hiking, gym, and always looking for the next adventure.',
    photos: sportsPhotos,
    icon: '🏀',
  },
  {
    title: 'Conferences & Events',
    subtitle: 'Sharing research at international venues — from IGARSS and EuSAR to ESA events and MENELAOS forums.',
    photos: conferencePhotos,
    icon: '🎤',
  },
];
---

<Layout
  title="Gallery — Reza M. Asiyabi"
  description="Personal gallery of Reza M. Asiyabi — travel, sports, and conference photos."
>
  <Nav />

  <main class="pt-24 pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page header -->
      <div class="text-center mb-16 fade-up">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-xs text-faint hover:text-muted transition-colors mb-6"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to home
        </a>
        <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
          Beyond the Research
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold text-foreground">Gallery</h1>
        <p class="text-muted text-sm mt-3 max-w-md mx-auto leading-relaxed">
          A glimpse into life outside the lab — travel, sport, and moments from conferences around the world.
        </p>
      </div>

      <!-- Gallery sections -->
      {
        sections.map((section, si) => (
          <div class="mb-20 fade-up" style={`transition-delay: ${si * 100}ms`}>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xl">{section.icon}</span>
              <h2 class="text-xl font-semibold text-foreground">{section.title}</h2>
              <span class="text-xs text-faint ml-1">({section.photos.length} photos)</span>
            </div>
            <p class="text-sm text-muted mb-6 ml-9 leading-relaxed">{section.subtitle}</p>

            <!-- Photo grid -->
            <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">
              {section.photos.map((photo) => (
                <button
                  class="group relative break-inside-avoid overflow-hidden rounded-xl bg-surface border border-stroke hover:border-accent/40 transition-all duration-300 w-full text-left cursor-zoom-in"
                  data-src={photo.src}
                  data-caption={photo.caption}
                  aria-label={`View ${photo.caption}`}
                >
                  <img
                    src={photo.src}
                    alt={photo.caption}
                    class="w-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                  />
                  <!-- Caption overlay -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
                    <p class="text-white text-xs leading-tight">{photo.caption}</p>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </main>

  <Footer />

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-8"
    style="display:none;"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <!-- Backdrop (click to close) -->
    <div id="lightbox-backdrop" class="absolute inset-0 bg-black/92 backdrop-blur-sm"></div>

    <!-- Prev arrow -->
    <button
      id="lightbox-prev"
      class="absolute left-2 sm:left-6 z-20 text-white/60 hover:text-white transition-colors p-3 rounded-full hover:bg-white/10"
      aria-label="Previous image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Image + caption -->
    <div class="relative z-10 flex flex-col items-center max-w-5xl w-full pointer-events-none">
      <!-- Close button -->
      <button
        id="lightbox-close"
        class="absolute -top-10 right-0 text-white/70 hover:text-white transition-colors p-2 pointer-events-auto"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[80vh] max-w-full rounded-xl shadow-2xl object-contain pointer-events-auto"
      />

      <!-- Counter + caption -->
      <div class="flex items-center gap-3 mt-4">
        <span id="lightbox-counter" class="text-white/40 text-xs tabular-nums"></span>
        <p id="lightbox-caption" class="text-white/70 text-sm text-center"></p>
      </div>
    </div>

    <!-- Next arrow -->
    <button
      id="lightbox-next"
      class="absolute right-2 sm:right-6 z-20 text-white/60 hover:text-white transition-colors p-3 rounded-full hover:bg-white/10"
      aria-label="Next image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</Layout>

<script>
  const lightbox  = document.getElementById('lightbox')!;
  const img       = document.getElementById('lightbox-img') as HTMLImageElement;
  const caption   = document.getElementById('lightbox-caption')!;
  const counter   = document.getElementById('lightbox-counter')!;
  const closeBtn  = document.getElementById('lightbox-close')!;
  const backdrop  = document.getElementById('lightbox-backdrop')!;
  const prevBtn   = document.getElementById('lightbox-prev')!;
  const nextBtn   = document.getElementById('lightbox-next')!;

  // Collect every gallery photo button in DOM order
  const allPhotos = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-src]'));
  let current = 0;

  function show(index: number) {
    current = (index + allPhotos.length) % allPhotos.length; // wrap around
    const btn = allPhotos[current];
    img.src = btn.dataset.src!;
    img.alt = btn.dataset.caption ?? '';
    caption.textContent = btn.dataset.caption ?? '';
    counter.textContent = `${current + 1} / ${allPhotos.length}`;
    // Dim arrows at boundaries (no wrap to signal start/end)
    prevBtn.style.opacity = current === 0 ? '0.25' : '1';
    nextBtn.style.opacity = current === allPhotos.length - 1 ? '0.25' : '1';
  }

  function open(index: number) {
    show(index);
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
    img.src = '';
  }

  // Open on photo click
  allPhotos.forEach((btn, i) => {
    btn.addEventListener('click', () => open(i));
  });

  // Arrow buttons
  prevBtn.addEventListener('click', () => show(current - 1));
  nextBtn.addEventListener('click', () => show(current + 1));

  // Close button and backdrop
  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  // Keyboard: Escape, ←, →
  document.addEventListener('keydown', (e) => {
    if (lightbox.style.display === 'none') return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
