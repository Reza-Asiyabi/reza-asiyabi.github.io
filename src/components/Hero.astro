---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16"
>
  <!-- Background gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-indigo-950/40 via-background to-background pointer-events-none"
  >
  </div>

  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="
    background-image:
      linear-gradient(rgba(99,102,241,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,1) 1px, transparent 1px);
    background-size: 48px 48px;
  "></div>

  <!-- Glow orb -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/10 rounded-full blur-3xl pointer-events-none"
  >
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Eyebrow -->
    <p
      class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-6 fade-up"
    >
      AI · Machine Learning · Earth Observation
    </p>

    <!-- Name -->
    <h1
      class="text-5xl sm:text-6xl lg:text-7xl font-bold text-foreground mb-5 leading-tight fade-up"
    >
      Reza M. Asiyabi
    </h1>

    <!-- Typewriter -->
    <div class="text-xl sm:text-2xl mb-6 h-9 fade-up flex items-center justify-center gap-1">
      <span id="typewriter" class="text-accent-light font-medium"></span>
      <span id="cursor" class="text-accent-light font-light">|</span>
    </div>

    <!-- Tagline -->
    <p
      class="text-base sm:text-lg text-muted max-w-2xl mx-auto mb-10 leading-relaxed italic fade-up"
    >
      "I build AI systems that try to understand the world rather than just fit
      the data."
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 fade-up">
      <a
        href="#experience"
        class="px-8 py-3 rounded-full bg-accent hover:bg-accent-light text-white font-medium transition-all duration-200 hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5"
      >
        View My Work
      </a>
      <a
        href="/files/Reza_CV.pdf"
        target="_blank"
        rel="noopener"
        class="px-8 py-3 rounded-full border border-stroke hover:border-accent text-muted hover:text-foreground font-medium transition-all duration-200 hover:-translate-y-0.5"
      >
        Download CV ↗
      </a>
    </div>

    <!-- Stats bar -->
    <div
      class="fade-up border-t border-stroke pt-10 grid grid-cols-2 sm:grid-cols-4 gap-8 stagger"
    >
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">4+</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Projects</div>
      </div>
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">20+</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Publications</div>
      </div>
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">570+</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Citations</div>
      </div>
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">6+</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Years Research</div>
      </div>
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">5+</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Institutions</div>
      </div>
      <div class="fade-up">
        <div class="text-4xl font-bold text-foreground">3</div>
        <div class="text-xs text-muted mt-1.5 tracking-wide uppercase">Continents</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#about"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-faint hover:text-muted transition-colors animate-bounce"
    aria-label="Scroll to about"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </a>
</section>

<script>
  const words = [
    'AI Researcher',
    'ML Engineer',
    'Earth Observation Scientist',
    'Postdoctoral Researcher',
  ];
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let pauseTimeout: ReturnType<typeof setTimeout> | null = null;

  const el = document.getElementById('typewriter')!;
  const cursor = document.getElementById('cursor')!;

  // Cursor blink
  setInterval(() => cursor.classList.toggle('opacity-0'), 530);

  function type() {
    const word = words[wordIndex];

    if (isDeleting) {
      el.textContent = word.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = word.substring(0, charIndex + 1);
      charIndex++;
    }

    if (!isDeleting && charIndex === word.length) {
      pauseTimeout = setTimeout(() => {
        isDeleting = true;
        type();
      }, 2200);
      return;
    }

    if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
    }

    setTimeout(type, isDeleting ? 55 : 95);
  }

  type();
</script>
