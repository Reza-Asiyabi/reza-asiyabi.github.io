---
// A curated selection of photos shown on the home page.
// Edit this list to change which photos are featured.
const featured = [
  { src: '/images/Travel/Interlaken.webp',                              caption: 'Paragliding, Swiss Alps' },
  { src: '/images/Conferences/Kuala Lumpor - IGARSS 2022 Presentation.webp', caption: 'IGARSS 2022, Kuala Lumpur' },
  { src: '/images/Travel/Venice - With Shaahin.webp',                   caption: 'Venice, Italy' },
  { src: '/images/Travel/Reykjavik - With Madison and Simon.webp',       caption: 'Reykjavik, Iceland' },
  { src: '/images/Conferences/Bonn - LPS.webp',                         caption: 'ESA LPS 2022, Bonn' },
  { src: '/images/Sports/Hiking.webp',                                  caption: 'Hiking' },
];

// Total photo count across the full gallery (update when you add photos)
const totalPhotos = 39;
---

<section id="gallery-preview" class="py-24 sm:py-32 bg-surface/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        Life Outside the Lab
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Gallery</h2>
      <p class="text-muted text-sm mt-3">
        Travel, sport, and conference moments from around the world.
      </p>
    </div>

    <!-- Photo grid: first photo tall, rest standard, last has "see all" overlay -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 fade-up">
      {featured.map((photo, i) => (
        <a
          href="/gallery"
          class={`group relative overflow-hidden rounded-xl bg-surface border border-stroke hover:border-accent/40 transition-all duration-300 ${i === 0 ? 'row-span-2' : ''}`}
          aria-label={i === featured.length - 1 ? `View all ${totalPhotos} photos` : photo.caption}
        >
          <img
            src={photo.src}
            alt={photo.caption}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            style={i === 0 ? 'min-height: 100%' : 'aspect-ratio: 4/3'}
            loading="lazy"
            decoding="async"
          />

          <!-- Regular caption overlay -->
          {i < featured.length - 1 && (
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
              <p class="text-white text-xs leading-tight">{photo.caption}</p>
            </div>
          )}

          <!-- Last photo: "see all" overlay (always visible) -->
          {i === featured.length - 1 && (
            <div class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors duration-300 flex flex-col items-center justify-center gap-1">
              <span class="text-white font-semibold text-lg">+{totalPhotos - featured.length + 1}</span>
              <span class="text-white/80 text-xs tracking-wide uppercase">View all</span>
            </div>
          )}
        </a>
      ))}
    </div>

    <div class="text-center mt-8 fade-up">
      <a
        href="/gallery"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-stroke hover:border-accent/50 text-muted hover:text-foreground font-medium text-sm transition-all duration-200 hover:-translate-y-0.5"
      >
        View full gallery
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
