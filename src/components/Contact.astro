---

<section id="contact" class="py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        Get In Touch
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Contact</h2>
      <p class="text-muted text-sm mt-4 max-w-lg mx-auto leading-relaxed">
        Open to research collaborations, industry opportunities, and interesting
        conversations. Feel free to reach out.
      </p>
    </div>

    <!-- Email CTA -->
    <div class="text-center mb-12 fade-up">
      <a
        href="mailto:reza.asiyabi@ed.ac.uk"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-surface border border-stroke hover:border-accent/50 hover:bg-accent/5 transition-all duration-300 group"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-accent group-hover:scale-110 transition-transform"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="text-foreground font-medium">reza.asiyabi@ed.ac.uk</span>
      </a>
    </div>

    <!-- Social grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 max-w-4xl mx-auto">
      {
        socialLinks.map((link, i) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? '_self' : '_blank'}
            rel="noopener"
            class="fade-up flex flex-col items-center gap-2 p-4 rounded-xl bg-surface border border-stroke hover:border-accent/50 hover:bg-accent/5 transition-all duration-300 text-center group"
            style={`transition-delay: ${i * 60}ms`}
          >
            <span class="text-muted group-hover:text-accent transition-colors" set:html={link.icon} />
            <span class="text-xs font-medium text-muted group-hover:text-foreground transition-colors">
              {link.label}
            </span>
          </a>
        ))
      }
    </div>

    <!-- Gallery link -->
    <div class="text-center mt-14 fade-up">
      <p class="text-faint text-sm">
        Want to see beyond the research?
        <a href="/gallery" class="text-accent hover:text-accent-light transition-colors ml-1"
          >Check out my gallery ↗</a
        >
      </p>
    </div>
  </div>
</section>
