---
// ─── ADD YOUR PERSONAL PROJECTS HERE ─────────────────────────────────────────
// Each project needs: title, description, tags, links, and status.
//
// status options:
//   'Live'        → green badge  (deployed, publicly accessible)
//   'In Progress' → amber badge  (actively being built)
//   'Completed'   → blue badge   (finished but not necessarily deployed)
//
// links: any combination of { label: 'GitHub', href: '...' },
//                            { label: 'Demo', href: '...' },
//                            { label: 'Write-up', href: '...' }, etc.
// ─────────────────────────────────────────────────────────────────────────────

const projects = [
  {
    title: 'AGB Assistant LLM',
    description:
      'A conversational AI chatbot built on top of OpenAI API for answering questions about Above Ground Biomass (AGB).',
    image: '/images/Projects/AGB_Chatbot.webp',
    tags: ['Python', 'LLM', 'NLP', 'OpenAI', 'Above Ground Biomass (AGB)'],
    links: [
      { label: 'GitHub', href: 'https://github.com/Reza-Asiyabi/AGB-Assistant-LLM' },
    ],
    status: 'Active',
  },
  {
    title: 'Job Application Assistant LLM',
    description:
      'An interactive AI toll built on top of OpenAI API and/or Ollama models as a personal assistant for job applications.',
    image: '/images/Projects/Job Application Assistant LLM.webp',
    tags: ['Python', 'LLM', 'NLP', 'OpenAI API', 'Ollama', 'Personal Assistant'],
    links: [
      { label: 'GitHub', href: 'https://github.com/Reza-Asiyabi/Job_Application_Assistant_LLM' },
    ],
    status: 'Active',
  },
  {
    title: 'GrAInt',
    description:
      'An interactive AI toll built on top of OpenAI API and as a personal assistant for drafting academic grant proposals.',
    image: '/images/Projects/GrAInt.webp',
    tags: ['Python', 'LLM', 'NLP', 'OpenAI API', 'Personal Assistant'],
    links: [
      { label: 'GitHub', href: 'https://github.com/Reza-Asiyabi/GrAInt' },
    ],
    status: 'Active',
  },
];

const statusColors: Record<string, string> = {
  'Live':        'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  'In Progress': 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  'Completed':   'bg-blue-500/15 text-blue-400 border-blue-500/30',
};
---

<section id="personal-projects" class="py-24 sm:py-32 bg-surface/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        Built for Fun & Curiosity
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Personal Projects</h2>
      <p class="text-muted text-sm mt-3">
        Side projects and tools I've built outside of work —
        <a
          href="https://github.com/reza-asiyabi"
          target="_blank"
          rel="noopener"
          class="text-accent hover:text-accent-light transition-colors"
        >
          more on GitHub ↗
        </a>
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        projects.map((project, i) => (
          <div
            class="fade-up bg-surface border border-stroke rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 hover:-translate-y-0.5 flex flex-col"
            style={`transition-delay: ${i * 80}ms`}
          >
            <!-- Project image -->
            {project.image && (
              <div class="relative h-40 bg-background overflow-hidden">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-contain p-4 opacity-90 hover:opacity-100 transition-opacity"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-surface/60 to-transparent" />
                <div class="absolute top-3 right-3">
                  <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${statusColors[project.status]}`}>
                    {project.status}
                  </span>
                </div>
              </div>
            )}

            <div class="p-6 flex flex-col flex-1">
              <!-- Header row (shown when no image) -->
              {!project.image && (
                <div class="flex items-start justify-between gap-3 mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7a2 2 0 012-2h4l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                  </svg>
                  <span class={`text-xs px-2.5 py-1 rounded-full border font-medium shrink-0 ${statusColors[project.status]}`}>
                    {project.status}
                  </span>
                </div>
              )}

              <h3 class="text-sm font-semibold text-foreground mb-2">{project.title}</h3>
              <p class="text-xs text-muted leading-relaxed mb-4 flex-1">{project.description}</p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.tags.map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-background border border-stroke text-faint">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex flex-wrap gap-4 pt-4 border-t border-stroke">
                {project.links.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener"
                    class="text-xs text-accent hover:text-accent-light transition-colors flex items-center gap-1"
                  >
                    {link.label === 'GitHub' && (
                      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                      </svg>
                    )}
                    {link.label} ↗
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
