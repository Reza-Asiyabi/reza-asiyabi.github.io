const filters = [
  { key: 'all', label: 'All' },
  { key: 'journal', label: 'Journals' },
  { key: 'conference', label: 'Conferences' },
  { key: 'preprint', label: 'Working Papers' },
  { key: 'dataset', label: 'Datasets' },
];

const typeColors: Record<string, string> = {
  journal: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  conference: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
  preprint: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  dataset: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
};

const typeLabels: Record<string, string> = {
  journal: 'Journal',
  conference: 'Conference',
  preprint: 'Working Paper',
  dataset: 'Dataset',
};
---

<section id="publications" class="py-24 sm:py-32 bg-surface/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        Research Output
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Publications</h2>
      <p class="text-muted text-sm mt-3">
        Selected publications —
        <a
          href="https://scholar.google.com/citations?user=jKpl5lQAAAAJ&hl=en"
          target="_blank"
          rel="noopener"
          class="text-accent hover:text-accent-light transition-colors"
        >
          full list on Google Scholar ↗
        </a>
      </p>
    </div>

    <!-- Filter buttons -->
    <div class="flex flex-wrap gap-2 justify-center mb-10 fade-up">
      {
        filters.map((f) => (
          <button
            data-filter={f.key}
            class={`filter-btn text-xs px-4 py-2 rounded-full border transition-all duration-200 ${
              f.key === 'all'
                ? 'bg-accent border-accent text-white'
                : 'bg-transparent border-stroke text-muted hover:border-accent/50 hover:text-foreground'
            }`}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <!-- Publication cards -->
    <div id="pub-grid" class="space-y-3">
      {
        publications.map((pub) => (
          <div
            data-type={pub.type}
            class="pub-card fade-up bg-surface border border-stroke rounded-xl p-5 hover:border-accent/40 transition-all duration-300"
          >
            <div class="flex flex-col sm:flex-row sm:items-start gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1.5">
                  <span
                    class={`text-xs px-2 py-0.5 rounded border ${typeColors[pub.type]}`}
                  >
                    {typeLabels[pub.type]}
                  </span>
                  {pub.featured && (
                    <span class="text-xs px-2 py-0.5 rounded border bg-accent/10 text-accent-light border-accent/20">
                      Featured
                    </span>
                  )}
                  <span class="text-xs text-faint">{pub.year}</span>
                </div>
                <h3 class="text-sm font-medium text-foreground leading-snug mb-1">
                  {pub.title}
                </h3>
                <p class="text-xs text-faint mb-1">{pub.authors}</p>
                <p class="text-xs text-muted italic">{pub.venue}</p>
              </div>
              {pub.links.length > 0 && (
                <div class="flex flex-wrap gap-2 shrink-0">
                  {pub.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener"
                      class="text-xs px-3 py-1.5 rounded-lg bg-background border border-stroke text-accent hover:border-accent/60 hover:bg-accent/5 transition-all whitespace-nowrap"
                    >
                      {link.label} ↗
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const pubCards = document.querySelectorAll<HTMLElement>('.pub-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active button style
      filterBtns.forEach((b) => {
        b.classList.remove('bg-accent', 'border-accent', 'text-white');
        b.classList.add('bg-transparent', 'border-stroke', 'text-muted');
      });
      btn.classList.add('bg-accent', 'border-accent', 'text-white');
      btn.classList.remove('bg-transparent', 'border-stroke', 'text-muted');

      // Show/hide cards
      pubCards.forEach((card) => {
        const show = filter === 'all' || card.dataset.type === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
