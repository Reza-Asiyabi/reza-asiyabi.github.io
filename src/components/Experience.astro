---

<section id="experience" class="py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        Where I've Worked
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Experience</h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="hidden sm:block absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-accent via-stroke to-transparent"
      >
      </div>

      <div class="space-y-10">
        {
          experiences.map((exp, i) => (
            <div
              class="fade-up relative sm:pl-10"
              style={`transition-delay: ${i * 60}ms`}
            >
              <!-- Timeline dot -->
              <div
                class={`hidden sm:flex absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 items-center justify-center ${
                  exp.current
                    ? 'bg-accent border-accent shadow-lg shadow-accent/40'
                    : 'bg-background border-stroke'
                }`}
              />

              <!-- Card -->
              <div class="bg-surface border border-stroke rounded-2xl p-6 hover:border-accent/40 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5">
                <!-- Header -->
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                  <div>
                    <h3 class="text-base font-semibold text-foreground">
                      {exp.role}
                      {exp.current && (
                        <span class="ml-2 text-xs px-2 py-0.5 rounded-full bg-accent/15 text-accent-light border border-accent/30">
                          Current
                        </span>
                      )}
                    </h3>
                    <p class="text-sm text-accent-light mt-0.5">{exp.org}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-xs text-muted font-medium">{exp.period}</div>
                    <div class="text-xs text-faint mt-0.5">{exp.location}</div>
                  </div>
                </div>

                <p class="text-sm text-muted leading-relaxed mb-4">{exp.description}</p>

                <ul class="space-y-1.5 mb-4">
                  {exp.highlights.map((h) => (
                    <li class="flex items-start gap-2 text-sm text-muted">
                      <span class="text-accent mt-1 shrink-0">▸</span>
                      {h}
                    </li>
                  ))}
                </ul>

                <!-- Tags -->
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {exp.tags.map((tag) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-background border border-stroke text-faint">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Links -->
                {exp.links.length > 0 && (
                  <div class="flex flex-wrap gap-3 pt-3 border-t border-stroke">
                    {exp.links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener"
                        class="text-xs text-accent hover:text-accent-light transition-colors flex items-center gap-1"
                      >
                        {link.label} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
