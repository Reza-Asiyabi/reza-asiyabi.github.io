---
const projects = [
  {
    title: 'Process-Guided Concept Bottleneck Models (PG-CBM)',
    description:
      'Physics-aware interpretable AI that combines domain knowledge with deep learning for biomass estimation from EO data. Models reason about underlying ecological mechanisms, not just statistical patterns.',
    image: '/images/Projects/PG-CBM.webp',
    tags: ['Physics-aware Deep Learning', 'Artificial Intelligence (AI)', 'Interpretable AI', 'SAR', 'Biomass', 'PyTorch', 'PyTorch'],
    links: [
      { Paper: 'Code', href: 'https://arxiv.org/abs/2601.10562' },
      { label: 'Code', href: 'https://github.com/Reza-Asiyabi/PG_CBM' },
      { label: 'NCEO', href: 'https://www.nceo.ac.uk/' },
    ],
    status: 'Active',
  },
  {
    title: 'Market Activity Index (MAI)',
    description:
      'Remote sensing system to detect and monitor informal rural markets in low-income countries using high-resolution satellite imagery. Enables real-time economic monitoring where ground data is absent.',
    image: '/images/Projects/MAI.webp',
    tags: ['Remote Sensing', 'Change Detection', 'Google Earth Engine'],
    links: [
      { label: 'Project', href: 'https://market-activity.net/' },
      { label: 'Paper', href: 'https://arxiv.org/abs/2407.12953' },
      { label: 'Code', href: 'https://github.com/Reza-Asiyabi/MAI' },
    ],
    status: 'Published',
  },
  {
    title: 'cvnnTorch: Complex-Valued Neural Network',
    description:
      'A Python package for implementing complex-valued neural networks based on PyTorch. Published in IEEE TGRS 2023.',
    tags: ['complex-valued Neural Network', 'Deep Learning', 'SAR', 'PyTorch', 'PyTorch'],
    links: [
      { label: 'Paper', href: 'https://ieeexplore.ieee.org/abstract/document/10102460/' },
      { label: 'Code', href: 'https://github.com/Reza-Asiyabi/cvnnTorch' }
    ],
    status: 'Published',
  },
  {
    title: 'ARTISTE: Complex-Valued Neural Data Compression for SAR data',
    description:
      'End-to-end complex-valued autoencoder architecture for compressing SAR raw data, preserving the phase coherency critical for interferometric and polarimetric applications. Published in IEEE J-STSP 2025.',
    image: '/images/Projects/CV_Compression.webp',
    tags: ['Deep Learning', 'Neural Data Compression', 'Complex Neural Networks', 'SAR', 'ESA', 'PyTorch', 'PyTorch'],
    links: [
      { label: 'Paper', href: 'https://ieeexplore.ieee.org/abstract/document/10955162' }
    ],
    status: 'Published',
  },
  {
    title: 'Segment-based Bag of Visual Words (Seg-BOVW)',
    description:
      'Segment-based bag of visual words (Seg-BOVW) model was developed for urban land cover classification using PolSAR data.',
    image: '/images/Projects/Seg-BOVW Flowchart.webp',
    tags: ['Machine Learning', 'Bag of Visual Words (BOVW)', 'Remote Sensing', 'SAR', 'Python'],
    links: [
      { label: 'Paper', href: 'https://www.sciencedirect.com/science/article/abs/pii/S0273117721008024' },
      { label: 'Code', href: 'https://github.com/Reza-Asiyabi/Seg-BOVW' },
    ],
    status: 'Published',
  },
];

const statusColors: Record<string, string> = {
  Active: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  Published: 'bg-blue-500/15 text-blue-400 border-blue-500/30',
};
---

<section id="projects" class="py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 fade-up">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-3">
        What I've Built
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground">
        Featured Projects
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {
        projects.map((project, i) => (
          <div
            class="fade-up bg-surface border border-stroke rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-300 hover:shadow-xl hover:shadow-accent/5 hover:-translate-y-1 flex flex-col"
            style={`transition-delay: ${i * 80}ms`}
          >
            <!-- Project image -->
            <div class="relative h-44 bg-background overflow-hidden">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-contain p-4 opacity-90 hover:opacity-100 transition-opacity"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface/60 to-transparent" />
              <!-- Status badge -->
              <div class="absolute top-3 right-3">
                <span
                  class={`text-xs px-2.5 py-1 rounded-full border font-medium ${statusColors[project.status]}`}
                >
                  {project.status}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-sm font-semibold text-foreground leading-snug mb-3">
                {project.title}
              </h3>
              <p class="text-xs text-muted leading-relaxed mb-4 flex-1">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.tags.map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-background border border-stroke text-faint">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex flex-wrap gap-3 pt-4 border-t border-stroke">
                {project.links.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener"
                    class="text-xs text-accent hover:text-accent-light transition-colors flex items-center gap-1"
                  >
                    {link.label} ↗
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
